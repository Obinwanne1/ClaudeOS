# ClaudeOS Environment Variables
# Copy to .env and fill in values

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# ClaudeOS Core
CLAUDEOS_SECRET_KEY=change-me-random-32-chars
CLAUDEOS_ENV=development
CLAUDEOS_VERSION=1.0.0

# Database
SQLITE_PATH=data/claudeos.db
CHROMADB_PATH=data/chromadb

# Flask API
FLASK_PORT=5000
FLASK_DEBUG=false

# Streamlit
STREAMLIT_PORT=8501

# Supabase (Phase 7 — leave blank for now)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Claude Memory Bridge
CLAUDE_MEMORY_PATH=C:\Users\rigwe\.claude\memory

# RECI Transport (optional — for transport-ops-agent)
RECI_DASHBOARD_DB=C:\Users\rigwe\Desktop\reci-transport-client-dashboard\data\dashboard.db

# Logging
LOG_LEVEL=INFO
LOG_PATH=logs
