# ============================================================
# ClaudeOS — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Core ─────────────────────────────────────────────────────
CLAUDEOS_ENV=development          # development | production
CLAUDEOS_SECRET_KEY=              # REQUIRED: random 32+ char secret (openssl rand -hex 32)
CLAUDEOS_VERSION=1.0.0

# ── Claude API ───────────────────────────────────────────────
ANTHROPIC_API_KEY=                # REQUIRED: your Anthropic API key

# ── Database ─────────────────────────────────────────────────
SQLITE_PATH=data/claudeos.db      # SQLite DB path (relative to project root)
CHROMADB_PATH=data/chromadb       # ChromaDB vector store path

# ── Flask / Streamlit ────────────────────────────────────────
FLASK_PORT=5000
STREAMLIT_PORT=8501
FLASK_DEBUG=false

# ── Security ─────────────────────────────────────────────────
# Comma-separated allowed CORS origins (no wildcard in production)
ALLOWED_ORIGINS=http://localhost:8501

# ── Scheduler ────────────────────────────────────────────────
SCHEDULER_TIMEZONE=Africa/Lagos   # IANA timezone string

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
LOG_PATH=logs

# ── Supabase Cloud Sync (Phase 7 — optional) ─────────────────
# Leave blank to disable sync. Required for multi-instance deployments.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=             # Service role key (server-side only)
SUPABASE_ACCESS_TOKEN=            # Personal access token for Management API
SYNC_INTERVAL_MIN=15              # Auto-sync frequency in minutes

# ── Email Notifications (Phase 14 — optional) ────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL=                     # Default recipient for system alerts

# ── Dev Shortcuts ────────────────────────────────────────────
# Static API key for dev/testing (bypasses JWT — disable in production)
# CLAUDEOS_DEV_API_KEY=

# ── Memory Bridge (optional) ─────────────────────────────────
# Path to an external Claude Code memory directory to import
CLAUDE_MEMORY_PATH=

# ── HuggingFace (optional) ───────────────────────────────────
# Set to 1 to prevent model downloads (use cached models only)
# HF_HUB_OFFLINE=1

# ── MCP Server (Phase 12 — optional) ────────────────────────
MCP_PORT=5100
